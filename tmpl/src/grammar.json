{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "ucode_tmpl",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "_raw_text"
            },
            "named": true,
            "value": "raw_text"
          },
          {
            "type": "SYMBOL",
            "name": "statement_tag"
          },
          {
            "type": "SYMBOL",
            "name": "expression_tag"
          },
          {
            "type": "SYMBOL",
            "name": "comment_tag"
          }
        ]
      }
    },
    "statement_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "open",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "{%-"
              },
              {
                "type": "STRING",
                "value": "{%+"
              },
              {
                "type": "STRING",
                "value": "{%"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "code",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_stmt_code"
                },
                "named": true,
                "value": "code"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "close",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "-%}"
              },
              {
                "type": "STRING",
                "value": "%}"
              }
            ]
          }
        }
      ]
    },
    "expression_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "open",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "{{-"
              },
              {
                "type": "STRING",
                "value": "{{"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "code",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_expr_code"
                },
                "named": true,
                "value": "code"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "close",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "-}}"
              },
              {
                "type": "STRING",
                "value": "}}"
              }
            ]
          }
        }
      ]
    },
    "comment_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "open",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "{#-"
              },
              {
                "type": "STRING",
                "value": "{#"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_comment_body"
                },
                "named": true,
                "value": "comment_content"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "close",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "-#}"
              },
              {
                "type": "STRING",
                "value": "#}"
              }
            ]
          }
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_raw_text"
    },
    {
      "type": "SYMBOL",
      "name": "_stmt_code"
    },
    {
      "type": "SYMBOL",
      "name": "_expr_code"
    },
    {
      "type": "SYMBOL",
      "name": "_comment_body"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}