{
  "grammars": [
    {
      "name": "ucode",
      "camelcase": "Ucode",
      "scope": "source.uc",
      "path": ".",
      "file-types": [
        "ucode", "uc", "ut"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "tags": [
        "queries/tags.scm"
      ],
      "injection-regex": "^ucode$"
    },
    {
      "name": "ucode_markup",
      "camelcase": "UcodeMarkup",
      "scope": "source.ucode.markup",
      "path": "./markup",
      "file-types": [
        "ucode", "uc", "ut"
      ],
      "content-regex": "(?m)^\\s*\\{[%{#]",
      "highlights": [
        "markup/queries/highlights.scm"
      ],
      "locals": [
        "markup/queries/locals.scm"
      ],
      "injections": [
        "markup/queries/injections.scm"
      ],
      "tags": [
        "markup/queries/tags.scm"
      ],
      "folds": [
        "markup/queries/folds.scm"
      ],
      "indents": [
        "markup/queries/indents.scm"
      ],
      "textobjects": [
        "markup/queries/textobjects.scm"
      ],
      "injection-regex": "^ucode_markup$"
    }
  ],
  "metadata": {
    "version": "0.3.0",
    "license": "MIT",
    "description": "Ucode grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/m00qek/tree-sitter-ucode"
    }
  },
  "bindings": {
    "node": true
  }
}
