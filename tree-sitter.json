{
  "grammars": [
    {
      "name": "ucode_tmpl",
      "camelcase": "UcodeTmpl",
      "scope": "source.uc.tmpl",
      "path": "./tmpl",
      "file-types": [
        "uc",
        "utpl"
      ],
      "content-regex": "(?m)^\\s*\\{[%{#]",
      "highlights": [
        "tmpl/queries/highlights.scm"
      ],
      "locals": [
        "tmpl/queries/locals.scm"
      ],
      "injections": [
        "tmpl/queries/injections.scm"
      ],
      "injection-regex": "^ucode_tmpl$"
    },
    {
      "name": "ucode",
      "camelcase": "Ucode",
      "scope": "source.uc",
      "path": ".",
      "file-types": [
        "uc"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "tags": [
        "queries/tags.scm"
      ],
      "injection-regex": "^ucode$"
    }
  ],
  "metadata": {
    "version": "0.3.0",
    "license": "MIT",
    "description": "Ucode grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/m00qek/tree-sitter-ucode"
    }
  },
  "bindings": {
    "node": true
  }
}
